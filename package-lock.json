{
  "name": "pullboard-node",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "pullboard-node",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@pullboard/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@pullboard/client": {
      "resolved": "packages/client",
      "link": true
    },
    "node_modules/pullboard": {
      "resolved": "packages/pullboard",
      "link": true
    },
    "packages/cli": {
      "name": "@pullboard/cli",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@pullboard/client": "^0.1.0"
      },
      "bin": {
        "pullboard": "bin/pullboard.js"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "packages/client": {
      "name": "@pullboard/client",
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/pullboard": {
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@pullboard/cli": "^0.1.0"
      },
      "bin": {
        "pullboard": "bin/pullboard.js"
      },
      "engines": {
        "node": ">=18"
      }
    }
  }
}
